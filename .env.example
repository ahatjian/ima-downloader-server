# ============================================================
# IMA 下载助手 Pro - 服务端环境变量配置
# ============================================================

# 基础配置（必须）
SECRET_KEY=your-secret-key-here
JWT_SECRET_KEY=your-jwt-secret-key-here
PORT=5000

# 数据库（可选，不配置则使用 SQLite）
# LeapCell 会自动注入 DATABASE_URL，无需手动配置
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# SMTP 邮箱配置（用于发送验证码邮件）
# 不配置则进入开发模式：验证码打印到控制台 + 通用验证码 888888
# 推荐使用 QQ 邮箱 SMTP：
#   1. 登录 mail.qq.com → 设置 → 账户 → 开启 SMTP 服务
#   2. 获取授权码（非 QQ 密码）
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USER=your-email@qq.com
SMTP_PASSWORD=your-smtp-authorization-code
SMTP_FROM_NAME=IMA下载助手

# 管理员说明
# 默认管理员邮箱: admin@ima-pro.local
# 开发模式下验证码: 888888
# 生产模式下通过 SMTP 发送真实验证码
