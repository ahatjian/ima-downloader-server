# ========================================
# IMA 下载助手 Pro - 服务端环境变量
# ========================================

# --- Flask 密钥（留空自动生成随机密钥）---
SECRET_KEY=
JWT_SECRET_KEY=

# --- 数据库（LeapCell 自动注入，本地开发填 SQLite 路径）---
DATABASE_URL=

# --- 管理员密码（管理后台登录用）---
ADMIN_PASSWORD=000000

# ========================================
# 登录方式：邮箱 + 密码
# ========================================
# 关闭公开注册，仅管理员可在后台创建用户。
# 管理员创建用户时设置邮箱、密码、配额和订阅等级（日/月/年卡）。
# 不再需要 SMTP 邮件配置。
# ========================================
