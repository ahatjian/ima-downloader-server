# IMA 下载助手 Pro - 环境配置模板
# 复制此文件为 .env 并填入实际值

# ============================================================
# 基础配置
# ============================================================
SECRET_KEY=your-secret-key-change-this
JWT_SECRET_KEY=your-jwt-secret-change-this
PORT=5000

# 数据库（Render.com 自动提供 DATABASE_URL，本地用 SQLite）
# DATABASE_URL=sqlite:///ima_pro.db

# ============================================================
# 腾讯云 SMS 配置
# 获取方式：https://console.cloud.tencent.com/smsv2
# 1. 创建应用 → 获取 SDKAppID
# 2. 创建签名 → 审核通过后获取 SignName
# 3. 创建正文模板 → 审核通过后获取 TemplateId
# 4. 访问管理 → API 密钥 → 获取 SecretId 和 SecretKey
# ============================================================
TENCENT_SMS_SECRET_ID=your-secret-id
TENCENT_SMS_SECRET_KEY=your-secret-key
TENCENT_SMS_SDK_APP_ID=your-sdk-app-id
TENCENT_SMS_SIGN_NAME=IMA下载助手
TENCENT_SMS_TEMPLATE_ID=123456

# 注意：不配置腾讯云密钥时，系统运行在开发模式：
# - 验证码打印到控制台
# - 通用验证码 888888 可登录任意手机号
# - 适合本地测试
