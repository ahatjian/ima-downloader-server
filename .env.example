# ========================================
# IMA 下载助手 Pro - 服务端环境变量
# ========================================

# --- Flask 密钥（留空自动生成随机密钥）---
SECRET_KEY=
JWT_SECRET_KEY=

# --- 数据库（LeapCell 自动注入，本地开发填 SQLite 路径）---
DATABASE_URL=

# --- 管理员密码 ---
ADMIN_PASSWORD=000000

# ========================================
# SMTP 邮件配置（用于发送验证码）
# ========================================
# 方案 A: SendGrid（推荐，海外部署可用）
#   SMTP_HOST=smtp.sendgrid.net
#   SMTP_PORT=587
#   SMTP_USER=apikey
#   SMTP_PASSWORD=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
#   SMTP_FROM_EMAIL=你的已验证邮箱@qq.com
#   SMTP_FROM_NAME=IMA下载助手
#
# 方案 B: QQ 邮箱（仅限国内服务器）
#   SMTP_HOST=smtp.qq.com
#   SMTP_PORT=465
#   SMTP_USER=你的QQ邮箱@qq.com
#   SMTP_PASSWORD=QQ邮箱授权码
#   SMTP_FROM_EMAIL=你的QQ邮箱@qq.com
#   SMTP_FROM_NAME=IMA下载助手
#
# 不配置 → 开发模式，验证码打印到日志，通用验证码 888888

SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=IMA下载助手
